# ─────────────────────────────────────────────────────────────────────────────
# MODUS Web Dashboard — Environment Variables
# Copy this to .env and fill in your values
# On Unraid: add these as environment variables when creating the container
# ─────────────────────────────────────────────────────────────────────────────

# ── Server-side (private) ─────────────────────────────────────────────────────

# Appwrite server-side API key
NUXT_APPWRITE_API_KEY=

# Discord bot token (for server-side API calls to Discord)
NUXT_DISCORD_BOT_TOKEN=

# Shared API key for bot → dashboard render requests (generate with: openssl rand -hex 32)
NUXT_RENDER_API_KEY=

# ── Public (client-side accessible) ──────────────────────────────────────────

# Appwrite endpoint URL
NUXT_PUBLIC_APPWRITE_ENDPOINT=https://api.ppo.gg/v1

# Appwrite project ID
NUXT_PUBLIC_APPWRITE_PROJECT_ID=69266f6e00118a9f6b58

# Base URL of the web dashboard (your domain or IP)
NUXT_PUBLIC_BASE_URL=https://bot.ppo.gg

# Comma-separated Discord user IDs that have admin access
NUXT_PUBLIC_BOT_ADMIN_IDS=

# Internal URL for the web dashboard to reach the bot's health/API endpoint
# On Unraid with a custom Docker network, use the container name:
#   http://modus-bot:3005
# If both containers share a bridge network, use the container IP or hostname
NUXT_PUBLIC_BOT_URL=http://modus-bot:3005

# Discord application client ID
NUXT_PUBLIC_DISCORD_CLIENT_ID=

# ── Native Discord OAuth (nuxt-auth-utils) ───────────────────────────────────
# When enabled, /api/auth/discord + /api/auth/callback do a direct Discord
# OAuth flow and store the session in a sealed cookie — no Appwrite
# dependency for auth. Existing Appwrite sessions keep working (cookies are
# still read as a fallback) until they expire naturally.
#
# BREAKING CHANGE when enabled: the session's userId is the Discord UID, not
# an Appwrite user ID. Existing `servers` rows were written with Appwrite
# user IDs in owner_id / admin_user_ids, so previously-registered servers
# won't recognize their owners until you re-register them via the dashboard
# /discover flow (or manually update the rows).
NUXT_USE_NATIVE_AUTH=false

# Required when NUXT_USE_NATIVE_AUTH=true. Get it from the Discord Developer
# Portal → OAuth2 → Client Secret. Never commit this.
NUXT_DISCORD_CLIENT_SECRET=

# Required by nuxt-auth-utils for sealed cookie sessions. Must be at least
# 32 characters. Generate with: `openssl rand -hex 32`
NUXT_SESSION_PASSWORD=

# ── Recording Storage (R2 / S3-compatible) ───────────────────────────────────
# Must match the bot's USE_R2_STORAGE setting. When enabled, the stream and
# delete endpoints talk to R2 instead of Appwrite Storage.
NUXT_USE_R2_STORAGE=false

# R2 credentials (same values as the bot's R2_* vars).
NUXT_R2_ACCOUNT_ID=
NUXT_R2_ACCESS_KEY_ID=
NUXT_R2_SECRET_ACCESS_KEY=
NUXT_R2_BUCKET=modus-recordings

# Optional custom endpoint. Leave blank to use the default R2 endpoint.
NUXT_R2_ENDPOINT=

# Presigned URL TTL in seconds (default 300).
NUXT_R2_PRESIGN_TTL=300

# ── Postgres ─────────────────────────────────────────────────────────────────
# Must match the bot's USE_POSTGRES / USE_POSTGRES_RECORDINGS settings.
#   NUXT_USE_POSTGRES=true              — full cutover; every list/CRUD
#                                         endpoint (tags, triggers, servers,
#                                         ai usage, stats, recordings) queries
#                                         Postgres directly.
#   NUXT_USE_POSTGRES_RECORDINGS=true   — narrow opt-in for recordings only.
NUXT_USE_POSTGRES=false
NUXT_USE_POSTGRES_RECORDINGS=false

# Postgres connection string — same value as the bot's DATABASE_URL.
NUXT_DATABASE_URL=
