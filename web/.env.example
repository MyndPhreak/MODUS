# ─────────────────────────────────────────────────────────────────────────────
# MODUS Web Dashboard — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Server-side (private) ─────────────────────────────────────────────────────

# Discord bot token (for server-side API calls to Discord)
NUXT_DISCORD_BOT_TOKEN=

# Shared API key for bot → dashboard render requests (generate with: openssl rand -hex 32)
NUXT_RENDER_API_KEY=

# ── Discord OAuth (native, via nuxt-auth-utils) ──────────────────────────────

# Discord OAuth Client Secret (Discord Developer Portal → OAuth2 → Client Secret).
NUXT_DISCORD_CLIENT_SECRET=

# Required by nuxt-auth-utils for sealed cookie sessions. Must be ≥ 32 chars.
# Generate with: openssl rand -hex 32
NUXT_SESSION_PASSWORD=

# ── Postgres (required) ──────────────────────────────────────────────────────
# Every server-side data endpoint goes through Drizzle + Postgres. When unset,
# endpoints return 503.
NUXT_DATABASE_URL=

# ── Redis (optional, recommended) ────────────────────────────────────────────
# Enables the dashboard's SSE bridge (/api/events/:channel) used for realtime
# log tail + module/config change notifications. When unset, the SSE endpoints
# return 503 and the admin logs page falls back to the initial snapshot only.
REDIS_URL=

# ── Object Storage (Cloudflare R2, required) ─────────────────────────────────
# Used for recording audio + welcome background images. Same credentials as
# the bot's R2_* vars.
NUXT_R2_ACCOUNT_ID=
NUXT_R2_ACCESS_KEY_ID=
NUXT_R2_SECRET_ACCESS_KEY=
NUXT_R2_BUCKET=modus-recordings

# Optional custom endpoint. Leave blank to use the default R2 endpoint.
NUXT_R2_ENDPOINT=

# Presigned URL TTL in seconds (default 300).
NUXT_R2_PRESIGN_TTL=300

# ── Public (client-side accessible) ──────────────────────────────────────────

# Base URL of the web dashboard (your domain or IP)
NUXT_PUBLIC_BASE_URL=https://bot.ppo.gg

# Comma-separated Discord user IDs that have admin access (bypasses the
# normal dashboard-role checks in the UI).
NUXT_PUBLIC_BOT_ADMIN_IDS=

# Internal URL for the web dashboard to reach the bot's health/API endpoint.
# On Unraid with a custom Docker network, use the container name:
#   http://modus-bot:3005
NUXT_PUBLIC_BOT_URL=http://modus-bot:3005

# Discord application client ID (used by the OAuth redirect URL).
NUXT_PUBLIC_DISCORD_CLIENT_ID=
