# ─────────────────────────────────────────────────────────────────────────────
# MODUS Bot — Environment Variables
# Copy this to .env and fill in your values
# On Unraid: add these as environment variables when creating the container
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Discord bot token (from Discord Developer Portal → Bot → Token)
DISCORD_TOKEN=

# Discord application/client ID (from Discord Developer Portal → General)
CLIENT_ID=

# ── Appwrite (for persisting settings & guild configs) ────────────────────────

# Appwrite API endpoint
APPWRITE_ENDPOINT=https://api.ppo.gg/v1

# Appwrite project ID
APPWRITE_PROJECT_ID=69266f6e00118a9f6b58

# Appwrite server-side API key (with databases read/write permissions)
APPWRITE_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────

# Health check server port (default: 3000)
BOT_PORT=3005

# ── Recording Storage (R2 / S3-compatible) ───────────────────────────────────
# When enabled, recordings upload to R2 instead of Appwrite Storage. Files in
# Appwrite Storage stay accessible — the flag only changes where NEW recordings
# are written. Intended as a cost-control migration path.
#
# Set to "true" to enable. Requires the four R2_* vars below.
USE_R2_STORAGE=false

# Cloudflare R2 credentials. Get them from:
#   Cloudflare dashboard → R2 → Manage R2 API Tokens → Create API Token
# Account ID is shown on the R2 overview page.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=modus-recordings

# Optional: custom endpoint override. Defaults to:
#   https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# Only set this if you're using a custom domain, S3-compatible provider other
# than R2 (e.g. Backblaze B2, MinIO), or the account-scoped endpoint.
R2_ENDPOINT=

# Optional: how long presigned playback URLs stay valid, in seconds. Default 300 (5 min).
R2_PRESIGN_TTL=300

# ── Recording Retention ──────────────────────────────────────────────────────
# Number of days to keep recordings. The bot runs a nightly sweep that deletes
# recordings (and their R2 objects / Appwrite files) older than this.
# Set to 0 to disable automatic cleanup.
RECORDING_RETENTION_DAYS=30

# ── Redis (optional, recommended for sharded deployments) ───────────────────
# When set, the bot uses Redis for:
#   - Cross-shard cache invalidation (module enable flags, module settings,
#     tag lookups) — writes on shard A are visible on shard B within a
#     pub/sub round-trip instead of waiting up to 60s for the local TTL.
#   - Leader election for background workers (recording retention sweep) so
#     only one shard runs at a time, with automatic failover when the
#     leader dies.
#
# Leave empty on single-process deployments; the bot degrades gracefully
# to in-process cache + shard-0 worker gate.
#
# Docker: redis://redis:6379  |  Managed (Upstash etc): rediss://…
REDIS_URL=

# ── Postgres ─────────────────────────────────────────────────────────────────
# Two opt-in flags:
#   USE_POSTGRES=true              — full cutover. Every collection (guild_configs,
#                                    servers, logs, modules, bot_status, milestones,
#                                    automod, AI usage, tags, temp voice, triggers,
#                                    and recordings) reads + writes Postgres.
#   USE_POSTGRES_RECORDINGS=true   — narrow opt-in for recordings only. Kept for
#                                    users who migrated in the first phase before
#                                    the other collections existed.
#
# Cutover workflow:
#   1. Apply schema:        pnpm --filter @modus/db run migrate
#   2. Dry-run import:      pnpm --filter @modus/db run migrate:all -- --dry-run
#   3. Copy historical:     pnpm --filter @modus/db run migrate:all
#   4. Flip the flag:       USE_POSTGRES=true + DATABASE_URL=…
USE_POSTGRES=false
USE_POSTGRES_RECORDINGS=false

# Postgres connection string. Example (Docker compose): postgres://modus:modus@postgres:5432/modus
DATABASE_URL=

# ── Welcome Image Rendering (offloaded to dashboard server) ──────────────────
# URL of the web dashboard (used to call the render API)
# Docker: http://modus-web:3000  |  Local dev: http://localhost:3000
DASHBOARD_URL=http://modus-web:3000

# Shared API key for bot → dashboard render requests (must match NUXT_RENDER_API_KEY)
RENDER_API_KEY=

# ── AI Module (Shared/Hosted Key — used as fallback when guilds don't supply their own) ─
# Provider: OpenAI | Groq | Google Gemini | Anthropic Claude | OpenAI Compatible
# Groq is recommended as a free default. https://console.groq.com
AI_PROVIDER=Groq
AI_API_KEY=
AI_MODEL=llama-3.3-70b-versatile
# Only needed for OpenAI Compatible providers (Ollama, LM Studio, etc.)
AI_BASE_URL=

# ── Web Search (SearXNG — self-hosted meta-search engine) ─────────────────────
# URL of your SearXNG instance. Required for the AI web_search tool.
# Deploy via Docker / Unraid Community Apps (search "SearXNG").
# Example: http://192.168.1.100:8080  or  http://searxng:8080 (Docker network)
SEARXNG_URL=

# ── Social Alerts (Twitch EventSub) ──────────────────────────────────────────

# Public HTTPS URL of the bot (used as EventSub callback base)
BOT_PUBLIC_URL=https://modus-bot.ppo.gg

# Twitch application credentials (from https://dev.twitch.tv)
# Required for Twitch stream online/offline alerts via EventSub.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Shared secret for verifying Twitch EventSub HMAC signatures.
# Must be 10–100 chars. Generate with: openssl rand -hex 24
# If omitted, an ephemeral secret is auto-generated each restart
# (subscriptions will be re-created on each restart — works but is noisy).
TWITCH_EVENTSUB_SECRET=

