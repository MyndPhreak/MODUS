# ─────────────────────────────────────────────────────────────────────────────
# MODUS Bot — Environment Variables
# Copy this to .env and fill in your values
# On Unraid: add these as environment variables when creating the container
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Discord bot token (from Discord Developer Portal → Bot → Token)
DISCORD_TOKEN=

# Discord application/client ID (from Discord Developer Portal → General)
CLIENT_ID=

# ── Appwrite (for persisting settings & guild configs) ────────────────────────

# Appwrite API endpoint
APPWRITE_ENDPOINT=https://api.ppo.gg/v1

# Appwrite project ID
APPWRITE_PROJECT_ID=69266f6e00118a9f6b58

# Appwrite server-side API key (with databases read/write permissions)
APPWRITE_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────

# Health check server port (default: 3000)
BOT_PORT=3005

# ── Welcome Image Rendering (offloaded to dashboard server) ──────────────────
# URL of the web dashboard (used to call the render API)
# Docker: http://modus-web:3000  |  Local dev: http://localhost:3000
DASHBOARD_URL=http://modus-web:3000

# Shared API key for bot → dashboard render requests (must match NUXT_RENDER_API_KEY)
RENDER_API_KEY=

# ── AI Module (Shared/Hosted Key — used as fallback when guilds don't supply their own) ─
# Provider: OpenAI | Groq | Google Gemini | Anthropic Claude | OpenAI Compatible
# Groq is recommended as a free default. https://console.groq.com
AI_PROVIDER=Groq
AI_API_KEY=
AI_MODEL=llama-3.3-70b-versatile
# Only needed for OpenAI Compatible providers (Ollama, LM Studio, etc.)
AI_BASE_URL=

# ── Social Alerts (Twitch EventSub) ──────────────────────────────────────────

# Public HTTPS URL of the bot (used as EventSub callback base)
BOT_PUBLIC_URL=https://modus-bot.ppo.gg

# Twitch application credentials (from https://dev.twitch.tv)
# Required for Twitch stream online/offline alerts via EventSub.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Shared secret for verifying Twitch EventSub HMAC signatures.
# Must be 10–100 chars. Generate with: openssl rand -hex 24
# If omitted, an ephemeral secret is auto-generated each restart
# (subscriptions will be re-created on each restart — works but is noisy).
TWITCH_EVENTSUB_SECRET=

