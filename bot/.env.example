# ─────────────────────────────────────────────────────────────────────────────
# MODUS Bot — Environment Variables
# Copy this to .env and fill in your values.
# On Unraid: add these as environment variables when creating the container.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required: Discord ────────────────────────────────────────────────────────

# Discord bot token (from Discord Developer Portal → Bot → Token)
DISCORD_TOKEN=

# Discord application/client ID (from Discord Developer Portal → General)
CLIENT_ID=

# ── Required: Postgres ──────────────────────────────────────────────────────
# All guild settings, recordings metadata, logs, etc. live here.
# Example (Docker compose): postgres://modus:modus@postgres:5432/modus
DATABASE_URL=

# ── Required: Cloudflare R2 (object storage) ────────────────────────────────
# Used for recording audio + welcome background images. Get credentials from:
#   Cloudflare dashboard → R2 → Manage R2 API Tokens → Create API Token
# The account ID is on the R2 overview page.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=modus-recordings

# Optional: custom endpoint override. Defaults to the R2 account URL.
# Set this for S3-compatible providers (B2, MinIO) or account-scoped endpoints.
R2_ENDPOINT=

# How long presigned playback URLs stay valid, in seconds. Default 300.
R2_PRESIGN_TTL=300

# ── Optional: Redis (recommended for sharded deployments) ───────────────────
# When set, enables:
#   - Cross-shard cache invalidation (module enable flags, module settings,
#     tag lookups) — writes on shard A are visible on shard B within a
#     pub/sub round-trip instead of waiting up to 60s for the local TTL.
#   - Leader election for background workers (recording retention sweep) so
#     only one shard runs at a time, with automatic failover.
#   - Dashboard realtime via SSE (log tail + module/config change events).
#
# Leave empty on single-process deployments; the bot falls back to the
# in-process cache + shard-0 worker gate, and the dashboard SSE stream
# is unavailable.
#
# Docker: redis://redis:6379   Managed (Upstash etc): rediss://…
REDIS_URL=

# ── Optional: general ───────────────────────────────────────────────────────

# Health check server port (default 3000; compose uses 3005)
BOT_PORT=3005

# Number of days to keep recordings. The bot runs a nightly sweep that
# deletes recordings (and their R2 objects) older than this. 0 = disabled.
RECORDING_RETENTION_DAYS=30

# ── Welcome Image Rendering (offloaded to dashboard server) ─────────────────
# URL of the web dashboard (used to call the render API).
# Docker: http://modus-web:3000   Local dev: http://localhost:3000
DASHBOARD_URL=http://modus-web:3000

# Shared API key for bot → dashboard render requests
# (must match NUXT_RENDER_API_KEY on the web side).
RENDER_API_KEY=

# ── AI Module (shared fallback key when guilds don't supply their own) ──────
# Provider: OpenAI | Groq | Google Gemini | Anthropic Claude | OpenAI Compatible
# Groq is a recommended free default. https://console.groq.com
AI_PROVIDER=Groq
AI_API_KEY=
AI_MODEL=llama-3.3-70b-versatile
# Only needed for OpenAI-compatible providers (Ollama, LM Studio, etc.).
AI_BASE_URL=

# ── Web Search (SearXNG — self-hosted meta-search engine) ───────────────────
# Required for the AI web_search tool. Deploy via Docker / Unraid Community
# Apps (search "SearXNG"). Example: http://searxng:8080
SEARXNG_URL=

# ── Social Alerts (Twitch EventSub) ─────────────────────────────────────────

# Public HTTPS URL of the bot (used as the EventSub callback base).
BOT_PUBLIC_URL=https://modus-bot.ppo.gg

# Twitch application credentials (https://dev.twitch.tv).
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Shared secret for verifying Twitch EventSub HMAC signatures.
# Must be 10–100 chars. Generate with: openssl rand -hex 24
# If omitted, an ephemeral secret is auto-generated each restart
# (subscriptions are recreated on each restart — works but noisy).
TWITCH_EVENTSUB_SECRET=

# ── TTS (Kokoro-FastAPI) ────────────────────────────────────────────────────
# Self-hosted text-to-speech. https://github.com/remsky/Kokoro-FastAPI
# Base URL of the Kokoro server. The /audio/speech path is appended automatically.
# Leave unset to disable TTS: /say won't register, and recording's
# announceMode="tts" will skip with a warning (recording itself still works).
KOKORO_BASE_URL=http://localhost:8880/v1
KOKORO_VOICE=af_bella
KOKORO_MODEL=kokoro
KOKORO_SPEED=1.0
# Optional bearer token if Kokoro is behind auth. Leave blank for no header.
KOKORO_API_KEY=
# Request timeout in ms. Generous default because long-text streams can take
# a while to finish generating on modest hardware.
KOKORO_REQUEST_TIMEOUT_MS=120000
