{
  "name": "modus",
  "version": "1.13.0",
  "private": true,
  "description": "MODUS — A modular Discord bot with web dashboard",
  "scripts": {
    "postinstall": "pnpm --filter @modus/db run build"
  },
  "pnpm": {
    "patchedDependencies": {
      "@discordjs/voice": "bot/patches/@discordjs__voice.patch"
    },
    "overrides": {
      "nitropack": ">=2.13.4",
      "devalue": ">=5.8.1",
      "fast-xml-parser": ">=5.7.0",
      "fast-xml-builder": ">=1.2.0",
      "esbuild": ">=0.25.0"
    }
  }
}
