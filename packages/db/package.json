{
  "name": "@modus/db",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Postgres schema, client, and repositories for MODUS",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./dist/schema.js"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./dist/client.js"
    },
    "./repositories/recordings": {
      "types": "./src/repositories/recordings.ts",
      "default": "./dist/repositories/recordings.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:baseline": "ts-node scripts/baseline-drizzle.ts",
    "migrate": "ts-node scripts/run-migrations.ts",
    "migrate:recordings": "ts-node scripts/migrate-recordings.ts",
    "migrate:all": "ts-node scripts/migrate-appwrite.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "node-appwrite": "^20.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
