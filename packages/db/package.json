{
  "name": "@modus/db",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Postgres schema, client, and repositories for MODUS",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./client": "./src/client.ts",
    "./repositories/recordings": "./src/repositories/recordings.ts"
  },
  "scripts": {
    "migrate": "ts-node scripts/run-migrations.ts",
    "migrate:recordings": "ts-node scripts/migrate-recordings.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "node-appwrite": "^20.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
